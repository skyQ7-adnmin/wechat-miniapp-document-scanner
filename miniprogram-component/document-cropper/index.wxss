/* document-cropper styles - WeChat Mini Program */

.cropper-container {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #000;
}

.preview-image {
  width: 100%;
  height: 100%;
}

/* Crop frame fill - light overlay, draggable */
.crop-fill {
  position: absolute;
  background: rgba(46, 117, 182, 0.05);
  z-index: 4;
}

/* Crop lines - blue, non-interactive */
.crop-line {
  position: absolute;
  background: rgba(46, 117, 182, 0.92);
  z-index: 5;
  pointer-events: none;
}

.crop-line-top,
.crop-line-bottom {
  height: 5rpx;
}

.crop-line-left,
.crop-line-right {
  width: 5rpx;
}

/* Edge handles - wider touch area */
.edge-handle {
  position: absolute;
  z-index: 6;
}

.edge-handle-top,
.edge-handle-bottom {
  height: 64rpx;
  margin-top: -32rpx;
}

.edge-handle-left,
.edge-handle-right {
  width: 64rpx;
  margin-left: -32rpx;
}

/* Corner handles - round blue dots */
.corner-handle {
  position: absolute;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: #2e75b6;
  border: 7rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  z-index: 7;
}

/* Hidden canvas for export - offscreen, not visible */
.hidden-canvas {
  position: absolute;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}
