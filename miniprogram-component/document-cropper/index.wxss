.cropper-container{position:relative;width:100%;height:100%;overflow:hidden;background:#111;}
.preview-image{width:100%;height:100%;}

/* White crop lines, semi-transparent */
.crop-line-t,.crop-line-b{position:absolute;height:3px;background:rgba(255,255,255,0.85);pointer-events:none;z-index:5;}
.crop-line-l,.crop-line-r{position:absolute;width:3px;background:rgba(255,255,255,0.85);pointer-events:none;z-index:5;}

/* Subtle corner indicators — small white/black dots */
.corner-handle{position:absolute;width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.9);border:2px solid rgba(0,0,0,0.5);margin-left:-14px;margin-top:-14px;z-index:10;}

/* Edge handles — invisible but large touch target */
.edge-handle{position:absolute;z-index:6;}
/* JS computes width/height per handle */

/* Crop fill — barely visible, large tap area for move */
.crop-fill{position:absolute;background:rgba(255,255,255,0.03);z-index:3;}

.hidden-canvas{position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;}
