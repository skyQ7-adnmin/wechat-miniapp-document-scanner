.container { padding: 12rpx; }
.toolbar { display:flex; gap:12rpx; margin-bottom:12rpx; }
.cropper-area { width:100%; height:500rpx; background:#000; border-radius:8rpx; overflow:hidden; }
.actions { display:flex; gap:8rpx; margin-top:12rpx; flex-wrap:wrap; }
.empty-state { display:flex; flex-direction:column; align-items:center; justify-content:center; height:400rpx; }
.empty-text { color:#999; margin-bottom:20rpx; }
.result { margin-top:20rpx; }
.result-title { font-size:28rpx; font-weight:bold; margin-bottom:8rpx; display:block; }
.result-image { width:100%; border-radius:8rpx; }
.gallery { margin-top:16rpx; }
.gallery-title { font-size:26rpx; font-weight:bold; display:block; margin-bottom:8rpx; }
.gallery-scroll { white-space:nowrap; }
.gallery-item { display:inline-flex; width:80rpx; height:80rpx; border-radius:8rpx; background:#eee; align-items:center; justify-content:center; margin-right:8rpx; position:relative; cursor:pointer; }
.gallery-item.active { border:3rpx solid #2e75b6; }
.gallery-delete { position:absolute; top:-8rpx; right:-8rpx; width:32rpx; height:32rpx; border-radius:50%; background:red; color:#fff; text-align:center; line-height:28rpx; font-size:24rpx; cursor:pointer; }
