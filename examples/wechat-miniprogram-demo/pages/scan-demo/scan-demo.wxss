.page{padding:12rpx;}
.mode-bar{display:flex;gap:8rpx;margin-bottom:12rpx;}
.cropper-wrap{width:100%;height:500rpx;background:#000;border-radius:8rpx;overflow:hidden;margin-bottom:12rpx;}
.actions{display:flex;gap:8rpx;flex-wrap:wrap;margin-bottom:8rpx;}
.status{background:#222;color:#0f0;font-size:22rpx;padding:8rpx;border-radius:4rpx;margin-bottom:8rpx;}
.result-block,.all-results{margin-top:12rpx;}
.result-title{font-size:26rpx;font-weight:bold;display:block;margin-bottom:8rpx;}
.result-img{width:100%;border-radius:8rpx;margin-bottom:8rpx;}
.gallery{margin-top:12rpx;}
.gallery-title{font-size:24rpx;font-weight:bold;display:block;margin-bottom:8rpx;}
.gallery-scroll{white-space:nowrap;}
.thumb{display:inline-flex;width:90rpx;height:90rpx;border-radius:8rpx;background:#eee;align-items:center;justify-content:center;margin-right:8rpx;position:relative;}
.thumb.active{border:3rpx solid #2e75b6;}
.thumb-num{font-size:24rpx;font-weight:bold;}
.thumb-ok{position:absolute;top:0;right:0;color:#0a0;font-size:20rpx;}
.thumb-del{position:absolute;top:-8rpx;right:-8rpx;width:32rpx;height:32rpx;border-radius:50%;background:#e33;color:#fff;text-align:center;line-height:28rpx;font-size:22rpx;}
