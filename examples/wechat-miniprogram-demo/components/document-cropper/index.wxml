<!-- document-cropper — All positions pre-computed in JS, no calc() or arithmetic in WXML -->
<view class="cropper-container">
  <image class="preview-image" src="{{src}}" mode="aspectFit" />

  <!-- Crop lines: pre-computed style strings in cropLines.topStyle etc. -->
  <view wx:if="{{showOverlay}}" class="crop-line-t" style="{{cropLines.topStyle}}" />
  <view wx:if="{{showOverlay}}" class="crop-line-b" style="{{cropLines.bottomStyle}}" />
  <view wx:if="{{showOverlay}}" class="crop-line-l" style="{{cropLines.leftStyle}}" />
  <view wx:if="{{showOverlay}}" class="crop-line-r" style="{{cropLines.rightStyle}}" />

  <!-- Corner handles: pre-computed style strings in cornerStyles[0..3] -->
  <view wx:if="{{showOverlay}}" wx:for="{{cornerStyles}}" wx:key="index"
        class="corner-handle" style="{{item}}"
        catchtouchstart="onTouchStart" catchtouchmove="onTouchMove" catchtouchend="onTouchEnd"
        data-mode="corner" data-index="{{index}}" />

  <!-- Edge handles: pre-computed style strings in edgeStyles[0..3] -->
  <view wx:if="{{showOverlay}}" wx:for="{{edgeStyles}}" wx:key="index"
        class="edge-handle" style="{{item}}"
        catchtouchstart="onTouchStart" catchtouchmove="onTouchMove" catchtouchend="onTouchEnd"
        data-mode="edge" data-index="{{index}}" />

  <!-- Move area: pre-computed style string -->
  <view wx:if="{{showOverlay}}" class="crop-fill" style="{{cropRect.moveStyle}}"
        catchtouchstart="onTouchStart" catchtouchmove="onTouchMove" catchtouchend="onTouchEnd"
        data-mode="move" />

  <canvas type="2d" id="cropCanvas" class="hidden-canvas" />
</view>
