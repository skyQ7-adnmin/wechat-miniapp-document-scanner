.crop-stage{position:relative;width:100%;height:100%;overflow:hidden;background:#111;}
.crop-img{width:100%;height:100%;}
/* RED debug border — highly visible */
.crop-overlay{position:absolute;box-sizing:border-box;border:4px solid #ff0000;background:rgba(255,0,0,0.08);z-index:50;pointer-events:auto;}
.crop-move{position:absolute;inset:0;z-index:51;}
.crop-corner{position:absolute;width:32px;height:32px;background:rgba(255,255,255,0.9);border:2px solid #ff0000;border-radius:4px;z-index:52;}
.crop-corner-tl{left:-16px;top:-16px;}
.crop-corner-tr{right:-16px;top:-16px;}
.crop-corner-br{right:-16px;bottom:-16px;}
.crop-corner-bl{left:-16px;bottom:-16px;}
.crop-diag{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.8);color:#0f0;font-size:10px;padding:4px;z-index:99;max-height:120px;overflow:auto;}
.crop-canvas{position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;z-index:0;}
