.crop-stage{position:relative;width:100%;height:100%;overflow:hidden;background:#111;}
.crop-img{width:100%;height:100%;}
.crop-box{position:absolute;box-sizing:border-box;border:3px solid #fff;box-shadow:0 0 0 1px #000,0 0 10px rgba(0,0,0,.7);z-index:50;}
.crop-move{position:absolute;left:0;top:0;right:0;bottom:0;z-index:51;}
.corner{position:absolute;width:28px;height:28px;background:#fff;border:2px solid #2e75b6;border-radius:50%;z-index:52;margin-left:-14px;margin-top:-14px;}
.corner-tl{left:0;top:0;}
.corner-tr{left:100%;top:0;}
.corner-br{left:100%;top:100%;}
.corner-bl{left:0;top:100%;}
.crop-canvas{position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;z-index:0;}
